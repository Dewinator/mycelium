# vectormemory-openclaw — Docker Environment Variables
# Copy this file to .env and fill in secure values:
#   cp .env.example .env

# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_to_a_secure_password
POSTGRES_DB=vectormemory
POSTGRES_PORT=54322

# ── PostgREST API ──────────────────────────────────────
API_PORT=54321
JWT_SECRET=CHANGE_ME_to_at_least_32_chars_random_string

# ── Ollama (Embedding Provider) ────────────────────────
OLLAMA_URL=http://host.docker.internal:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
